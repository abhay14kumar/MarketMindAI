<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      Human-readable local output is the default. The pattern is externally
      overridable and includes MDC correlation without logging request bodies,
      uploaded files, portfolio values, authorization data, or secrets.

      A future deployment profile can replace this encoder with Spring Boot's
      StructuredLogEncoder without changing application logging calls.
    -->
    <property
            name="CONSOLE_LOG_PATTERN"
            value="${CONSOLE_LOG_PATTERN:-%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] [correlationId=%X{correlationId:-none}] %logger{36} - %msg %kvp%n%ex}"/>
    <springProperty
            scope="context"
            name="BACKEND_LOG_FILE"
            source="logging.file.name"
            defaultValue="logs/marketmind-backend.log"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <springProfile name="local">
        <appender name="BACKEND_FILE"
                  class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${BACKEND_LOG_FILE}</file>
            <append>true</append>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${CONSOLE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>
                    ${BACKEND_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz
                </fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>250MB</totalSizeCap>
                <cleanHistoryOnStart>true</cleanHistoryOnStart>
            </rollingPolicy>
        </appender>

        <root level="${ROOT_LOG_LEVEL:-INFO}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="BACKEND_FILE"/>
        </root>
    </springProfile>

    <springProfile name="!local">
        <root level="${ROOT_LOG_LEVEL:-INFO}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
