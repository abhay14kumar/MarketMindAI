# MarketMind AI local development environment.
# Copy to docker/.env before running Docker Compose.
# These are local-only development credentials, never production secrets.

TZ=UTC

# Container images
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:latest
PGADMIN_IMAGE=dpage/pgadmin4:latest

# PostgreSQL
POSTGRES_DB=marketmind
POSTGRES_USER=marketmind_user
POSTGRES_PASSWORD=marketmind_pass
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=marketmind_redis_pass
REDIS_PORT=6379

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=marketmind_qdrant_key

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@marketmind.local
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Spring Boot backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# React frontend
VITE_BACKEND_URL=http://localhost:8080

# AI service
AI_SERVICE_PORT=8000
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
MARKET_PROVIDER=LOCAL
ENABLE_SCHEDULER=true
ENABLE_NSE_FETCHER=true
ENABLE_BSE_FETCHER=true

# RAG and generation defaults
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MAX_TOKENS=4096
TEMPERATURE=0.1

# Bounded Docker JSON log rotation
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# Local resource limits
POSTGRES_CPUS=1.0
POSTGRES_MEMORY_LIMIT=1g
POSTGRES_MEMORY_RESERVATION=256m
REDIS_CPUS=0.5
REDIS_MEMORY_LIMIT=512m
REDIS_MEMORY_RESERVATION=64m
QDRANT_CPUS=1.0
QDRANT_MEMORY_LIMIT=1g
QDRANT_MEMORY_RESERVATION=256m
PGADMIN_CPUS=0.5
PGADMIN_MEMORY_LIMIT=512m
PGADMIN_MEMORY_RESERVATION=128m
